
# ──────────────────────────────────────────────────────────────────────────────
# AI Task Decomposition Copilot — Environment Variables
# CSC 7644: Applied LLM Development
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI API key — required for the LLM Planner (Phase 2+)
# Obtain from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# OpenAI model to use for the planner
# Recommended: gpt-4o or gpt-4-turbo for reliable JSON-only outputs
OPENAI_MODEL=gpt-4o

# Maximum tokens allowed in a single planner response
# Increase if generating complex multi-step plans
OPENAI_MAX_TOKENS=1024

# Maximum number of retry attempts for malformed planner outputs
# Must be a positive integer (recommended: 3)
MAX_RETRIES=3

# Path to the sandboxed workspace directory (relative to project root)
# The file.read tool will ONLY allow reads from within this directory
WORKSPACE_DIR=./workspace

# Log level — controls verbosity of the controller loop output
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
